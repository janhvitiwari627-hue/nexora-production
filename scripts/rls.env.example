# Environment variables for running the RLS test suite locally.
# Copy this file to scripts/rls.env, fill in the values, and source it before running:
#
#   cp scripts/rls.env.example scripts/rls.env
#   # edit scripts/rls.env with your real values
#   source scripts/rls.env
#   bun run test:rls

# Supabase project URL (found in Supabase project settings → API)
SUPABASE_URL=https://<your-project>.supabase.co

# Supabase publishable (anon) key
SUPABASE_PUBLISHABLE_KEY=<publishable-key>

# Supabase service role key — required to seed/cleanup test users and rows.
# Keep this secret; never commit it.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional: directory where RLS test artifacts are written.
# When set, the suite writes supabase-requests.log, failure-details.json,
# assertion-timings.json, and rls-output.log here.
RLS_LOG_DIR=./rls-artifacts
